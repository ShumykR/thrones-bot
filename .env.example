# === ThroneChat Bot Configuration ===

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Bot username (without @)
BOT_USERNAME=ThroneChatBot

# Telegram Group Chat ID where the game takes place
# (send /chatid in the group to discover, or use @userinfobot)
CHAT_ID=-1001234567890

# WebApp server settings
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# WebApp public URL (ngrok for dev, your domain for prod)
# Required for Telegram WebApp (must be HTTPS)
WEBAPP_URL=https://your-ngrok-url.ngrok-free.app

# Database path (SQLite)
DATABASE_PATH=./thronebot.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
